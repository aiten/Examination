{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=Ait1\\SQLEXPRESS;Initial Catalog=Examination;Integrated Security=True;Encrypt=False;Trust Server Certificate=False",
    "DefaultConnection2": "Data Source=(localdb)\\MSSQLLocalDB;Initial Catalog=Examination;Integrated Security=True"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "MSSqlServer",
        "Args": {
          "connectionString": "DefaultConnection",
          "sinkOptions": {
            "tableName": "AuditLogs",
            "autoCreateSqlTable": false
          },
          "restrictedToMinimumLevel": "Warning"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName" ]
  },
  "Keycloak": {
    "Realm": "ait",
    "AuthServerUrl": "https://auth.aitenbichler.cc",
    "SslRequired": "external",
    "Resource": "examination",
    "credentials": {
      "secret": "VE9WQMVogQblqi6mCHzlAJHAMDCpRw4C"
    },
    "PublicClient": true,
    "ConfidentialPort": 0,
    "VerifyTokenAudience": false
  },
  "AllowedHosts": "*"
